---
import type { CollectionEntry } from 'astro:content';
import RecipeCard from './RecipeCard.astro';

interface Props {
  recipes: CollectionEntry<'recipes'>[];
}

const { recipes } = Astro.props;
// server-rendered order is the "Newest" default, matching the sort dropdown's default option
const sorted = [...recipes].sort((a, b) => b.data.created.getTime() - a.data.created.getTime());
---

<div class="grid-controls">
  <input type="search" id="recipe-search" placeholder="Search recipes, ingredients, cuisine..." />
  <div class="sort-control">
    <label for="sort-select">Sort by</label>
    <select id="sort-select">
      <option value="newest">Newest</option>
      <option value="title">Title (A-Z)</option>
      <option value="protein-desc">Protein (high to low)</option>
      <option value="calories-asc">Calories (low to high)</option>
    </select>
  </div>
</div>

<p id="no-results" class="recipe-meta" style="display: none;">No recipes match your search.</p>

<div id="recipe-grid">
  {sorted.map((recipe) => <RecipeCard recipe={recipe} />)}
</div>

<script>
  const search = document.getElementById('recipe-search') as HTMLInputElement;
  const select = document.getElementById('sort-select') as HTMLSelectElement;
  const grid = document.getElementById('recipe-grid')!;
  const noResults = document.getElementById('no-results')!;

  function sortCards(mode: string) {
    const cards = Array.from(grid.querySelectorAll<HTMLElement>('.recipe-card'));
    cards.sort((a, b) => {
      switch (mode) {
        case 'title':
          return a.dataset.title!.localeCompare(b.dataset.title!);
        case 'protein-desc':
          return parseFloat(b.dataset.protein!) - parseFloat(a.dataset.protein!);
        case 'calories-asc':
          return parseFloat(a.dataset.calories!) - parseFloat(b.dataset.calories!);
        case 'newest':
        default:
          return new Date(b.dataset.created!).getTime() - new Date(a.dataset.created!).getTime();
      }
    });
    cards.forEach((card) => grid.appendChild(card));
  }

  function filterCards(query: string) {
    const q = query.trim().toLowerCase();
    const cards = Array.from(grid.querySelectorAll<HTMLElement>('.recipe-card'));
    let visibleCount = 0;
    cards.forEach((card) => {
      const matches = q === '' || card.dataset.search!.includes(q);
      card.style.display = matches ? '' : 'none';
      if (matches) visibleCount++;
    });
    noResults.style.display = visibleCount === 0 ? 'block' : 'none';
  }

  select.addEventListener('change', () => sortCards(select.value));
  search.addEventListener('input', () => filterCards(search.value));
</script>
