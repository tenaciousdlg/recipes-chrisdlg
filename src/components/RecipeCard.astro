---
import type { CollectionEntry } from 'astro:content';
import { getPrimaryIngredient } from '../lib/scale';
import { isHighProtein } from '../lib/macros';

interface Props {
  recipe: CollectionEntry<'recipes'>;
}

const { recipe } = Astro.props;
const primary = getPrimaryIngredient(recipe.data.ingredients);
const calories = recipe.data.macros_per_serving?.calories ?? 0;
const protein = recipe.data.macros_per_serving?.protein_g ?? 0;

// searchable blob: title, description, cuisine/category/season, tags, and every
// ingredient name, so typing e.g. "chicken thigh" or "cold" surfaces matching recipes
const searchIndex = [
  recipe.data.title,
  recipe.data.description ?? '',
  recipe.data.cuisine ?? '',
  recipe.data.category,
  recipe.data.season,
  ...recipe.data.tags,
  ...recipe.data.ingredients.map((i) => i.item),
]
  .join(' ')
  .toLowerCase();
---

<div
  class="recipe-card"
  data-title={recipe.data.title.toLowerCase()}
  data-created={recipe.data.created.toISOString()}
  data-protein={protein}
  data-calories={calories}
  data-search={searchIndex}
>
  <a class="recipe-card-link" href={`/recipes/${recipe.id}/`}>
    <h2>
      {recipe.data.title}
      {recipe.data.category !== 'main' && <span class="tag category-tag">{recipe.data.category}</span>}
    </h2>
    <p>{recipe.data.description}</p>
    <div class="recipe-meta">
      {recipe.data.base_servings} servings from {primary.qty} {primary.unit} {primary.item}
      {recipe.data.cuisine ? ` · ${recipe.data.cuisine}` : ''}
    </div>
  </a>
  <div class="tags">
    {isHighProtein(recipe.data.macros_per_serving) && <span class="tag">high-protein</span>}
    {recipe.data.tags.map((tag) => <a class="tag" href={`/tags/${tag}/`}>{tag}</a>)}
  </div>
</div>
