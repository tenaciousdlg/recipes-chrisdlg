---
import { load as parseYaml } from 'js-yaml';
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
// ?raw has Vite inline the file's text at build time; node:fs isn't available
// in the Cloudflare-adapter's Workers-emulated prerender step.
import menuYamlRaw from '../data/menu.yaml?raw';

interface MenuItem {
  label: string;
  recipe?: string;
  source_url?: string;
}
interface MenuSection {
  section: string;
  items: MenuItem[];
}

const menu = parseYaml(menuYamlRaw) as MenuSection[];
const recipeIds = new Set((await getCollection('recipes')).map((r) => r.id));

// cross-check against the real collection rather than trusting the yaml's `recipe`
// field blindly, so a renamed/removed recipe shows back up as a gap
const sections = menu.map((s) => ({
  ...s,
  items: s.items.map((item) => ({ ...item, built: item.recipe !== undefined && recipeIds.has(item.recipe) })),
}));

const totalItems = sections.reduce((sum, s) => sum + s.items.length, 0);
const totalBuilt = sections.reduce((sum, s) => sum + s.items.filter((i) => i.built).length, 0);
---

<Layout title="Menu" description="The master cookbook wishlist, checked off against what's actually been built.">
  <a href="/">&larr; all recipes</a>
  <h1>Menu</h1>
  <p class="recipe-meta">{totalBuilt} / {totalItems} built</p>

  {sections.map((s) => {
    const builtCount = s.items.filter((i) => i.built).length;
    return (
      <div class="box">
        <h2>{s.section} <span class="recipe-meta">({builtCount}/{s.items.length})</span></h2>
        <ul class="menu-list">
          {s.items.map((item) => (
            <li class={item.built ? 'menu-built' : 'menu-gap'}>
              {item.built ? (
                <>
                  <span class="menu-check">&check;</span>
                  <a href={`/recipes/${item.recipe}/`}>{item.label}</a>
                </>
              ) : (
                <>
                  <span class="menu-check">&mdash;</span>
                  <span>{item.label}</span>
                  {item.source_url && (
                    <>
                      {' '}
                      <a href={item.source_url}>(reference)</a>
                    </>
                  )}
                </>
              )}
            </li>
          ))}
        </ul>
      </div>
    );
  })}
</Layout>
