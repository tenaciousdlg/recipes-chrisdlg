---
import { load as parseYaml } from 'js-yaml';
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { getPrimaryIngredient, unitLabel } from '../lib/scale';
// ?raw has Vite inline the file's text at build time, no runtime fs access needed --
// node:fs isn't available in the Cloudflare-adapter's Workers-emulated prerender step.
import ingredientsYamlRaw from '../data/ingredients.yaml?raw';

const recipes = (await getCollection('recipes')).sort((a, b) => a.data.title.localeCompare(b.data.title));

const recipesForClient = recipes.map((r) => {
  const primary = getPrimaryIngredient(r.data.ingredients);
  return {
    id: r.id,
    title: r.data.title,
    primaryQty: primary.qty,
    primaryUnit: primary.unit,
    primaryItem: primary.item,
    ingredients: r.data.ingredients.map((i) => ({
      item: i.item,
      qty: i.qty,
      unit: i.unit,
      primary: i.primary,
      scale: i.scale,
      section: i.section,
    })),
  };
});

// searchable blob per picker row, mirroring the homepage card index (title, description,
// cuisine, category, season, tags, primary ingredient) so "greek" finds the same recipes
// here as it does there. Server-rendered as a data attribute, not part of the JSON payload.
const searchIndexById = new Map(
  recipes.map((r) => {
    const primary = getPrimaryIngredient(r.data.ingredients);
    const blob = [
      r.data.title,
      r.data.description ?? '',
      r.data.cuisine ?? '',
      r.data.category,
      r.data.season,
      ...r.data.tags,
      primary.item,
    ]
      .join(' ')
      .toLowerCase();
    return [r.id, blob];
  }),
);

// grams-per-unit for each ingredient, used client-side to reconcile the same item
// listed under different units across recipes (e.g. ginger by tbsp in one, tsp in
// another) into a single line instead of two duplicate ones.
interface IngredientEntry {
  grams_per_unit: Record<string, number>;
}
const ingredientsYaml = parseYaml(ingredientsYamlRaw) as Record<string, IngredientEntry>;
const gramConversions = Object.fromEntries(
  Object.entries(ingredientsYaml).map(([item, data]) => [item, data.grams_per_unit]),
);
---

<Layout title="Shopping List" description="Aggregate scaled ingredients from selected recipes into a store-section shopping list.">
  <a href="/">&larr; all recipes</a>
  <h1>Shopping List</h1>
  <p>
    Check off what you're making and adjust each to how much, ingredients aggregate below by store
    section. Tick an ingredient you already have and it stays visible but drops off the copied list.
  </p>

  <input type="search" id="picker-search" placeholder="Filter recipes... (title, cuisine, tag)" />

  <div class="box" id="recipe-picker">
    {recipesForClient.map((r) => (
      <div class="picker-row" data-search={searchIndexById.get(r.id)}>
        <label class="picker-label">
          <input type="checkbox" class="recipe-check" data-id={r.id} />
          {r.title}
        </label>
        <span class="picker-scale">
          <input type="number" step="any" min="0" class="recipe-qty" data-id={r.id} value={r.primaryQty} />
          {[unitLabel(r.primaryUnit), r.primaryItem].filter(Boolean).join(' ')}
        </span>
      </div>
    ))}
  </div>

  <div class="list-actions">
    <button id="copy-list" type="button">Copy list</button>
    <button id="clear-all" type="button">Clear all</button>
    <span id="copy-confirm" class="copy-confirm"></span>
  </div>

  <p id="empty-state" class="recipe-meta">No recipes selected yet.</p>
  <div id="shopping-list-output"></div>

  <script type="application/json" id="recipes-data" set:html={JSON.stringify(recipesForClient)} />
  <script type="application/json" id="gram-conversions-data" set:html={JSON.stringify(gramConversions)} />
</Layout>

<script>
  import {
    aggregateIngredients,
    groupBySection,
    type AggregatedLine,
    type SelectedRecipe,
    type GramConversions,
  } from '../lib/shoppingList';
  import { formatQty, formatMeasure } from '../lib/scale';
  import type { ScalableIngredient } from '../lib/scale';

  interface RecipeForClient {
    id: string;
    title: string;
    primaryQty: number;
    primaryUnit: string;
    primaryItem: string;
    ingredients: ScalableIngredient[];
  }

  interface RowState {
    checked: boolean;
    qty: number;
  }

  const dataEl = document.getElementById('recipes-data')!;
  const recipesForClient: RecipeForClient[] = JSON.parse(dataEl.textContent!);
  const conversionsEl = document.getElementById('gram-conversions-data')!;
  const gramConversions: GramConversions = JSON.parse(conversionsEl.textContent!);
  const STORAGE_KEY = 'recipes-chrisdlg:shopping-list';
  const PANTRY_KEY = 'recipes-chrisdlg:pantry';

  const picker = document.getElementById('recipe-picker')!;
  const output = document.getElementById('shopping-list-output')!;
  const emptyState = document.getElementById('empty-state')!;
  const copyBtn = document.getElementById('copy-list')!;
  const copyConfirm = document.getElementById('copy-confirm')!;
  const clearBtn = document.getElementById('clear-all')!;

  function loadState(): Record<string, RowState> {
    try {
      return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
    } catch {
      return {};
    }
  }

  // pantry-lite: items marked "already have it". Keyed by item name and persisted, so a
  // leftover from last week's cooking (the other 3/4 red onion) stays off the copied list
  // until you untick it. Lines stay visible, struck out, so the skip is a conscious one.
  function loadPantry(): Record<string, true> {
    try {
      return JSON.parse(localStorage.getItem(PANTRY_KEY) || '{}');
    } catch {
      return {};
    }
  }
  const pantry = loadPantry();

  // produce bought by the piece rounds up to whole items -- nobody buys 1/4 of a red
  // onion. The exact need is kept alongside so the leftover is a known quantity.
  function lineDisplay(l: AggregatedLine): { qty: string; need: string | null } {
    if (l.unit === 'count') {
      const exact = Math.round(l.qty * 1000) / 1000;
      const buy = Math.ceil(exact);
      return { qty: formatQty(buy), need: buy !== exact ? formatQty(exact) : null };
    }
    return { qty: formatMeasure(l.qty, l.unit), need: null };
  }

  // a qty box that's empty mid-edit parses to NaN; falling back to the last good value
  // (or the recipe default) keeps a checked recipe on the list instead of silently
  // dropping it while the user types
  const defaultQty = new Map(recipesForClient.map((r) => [r.id, r.primaryQty]));
  const lastGoodQty: Record<string, number> = {};

  function currentState(): Record<string, RowState> {
    const state: Record<string, RowState> = {};
    picker.querySelectorAll<HTMLInputElement>('.recipe-check').forEach((cb) => {
      const id = cb.dataset.id!;
      const qtyInput = picker.querySelector<HTMLInputElement>(`.recipe-qty[data-id="${id}"]`)!;
      const parsed = parseFloat(qtyInput.value);
      const qty = Number.isNaN(parsed) ? lastGoodQty[id] ?? defaultQty.get(id)! : parsed;
      lastGoodQty[id] = qty;
      state[id] = { checked: cb.checked, qty };
    });
    return state;
  }

  function selectedFromState(state: Record<string, RowState>): SelectedRecipe[] {
    return recipesForClient
      .filter((r) => state[r.id]?.checked && !Number.isNaN(state[r.id].qty))
      .map((r) => ({
        title: r.title,
        primaryQty: r.primaryQty,
        targetQty: state[r.id].qty,
        ingredients: r.ingredients,
      }));
  }

  function render() {
    const state = currentState();
    localStorage.setItem(STORAGE_KEY, JSON.stringify(state));

    const selected = selectedFromState(state);
    if (selected.length === 0) {
      output.innerHTML = '';
      emptyState.style.display = 'block';
      return;
    }
    emptyState.style.display = 'none';

    const groups = groupBySection(aggregateIngredients(selected, gramConversions));
    output.innerHTML = groups
      .map(
        (g) => `
      <div class="ingredient-group">
        <h3>${g.section}</h3>
        <ul class="ingredient-list">
          ${g.lines
            .map((l) => {
              const d = lineDisplay(l);
              const have = !!pantry[l.item];
              const note = [d.need ? `need ${d.need}` : null, l.recipes.join(', ')].filter(Boolean).join(' · ');
              return `
            <li class="${have ? 'have-it' : ''}">
              <input type="checkbox" class="have-check" data-item="${l.item}" ${have ? 'checked' : ''} title="already have it" />
              <span class="qty">${d.qty}</span>
              <span>${l.item} <span class="fixed-note">(${note})</span></span>
            </li>`;
            })
            .join('')}
        </ul>
      </div>`,
      )
      .join('');
  }

  function applyState(state: Record<string, RowState>) {
    picker.querySelectorAll<HTMLInputElement>('.recipe-check').forEach((cb) => {
      const id = cb.dataset.id!;
      if (!state[id]) return;
      cb.checked = !!state[id].checked;
      const qtyInput = picker.querySelector<HTMLInputElement>(`.recipe-qty[data-id="${id}"]`)!;
      if (state[id].qty != null && !Number.isNaN(state[id].qty)) qtyInput.value = String(state[id].qty);
    });
  }

  applyState(loadState());
  render();

  picker.addEventListener('input', render);
  picker.addEventListener('change', render);

  // "have it" toggles live inside the re-rendered output, so listen on the container
  output.addEventListener('change', (e) => {
    const t = e.target as HTMLInputElement;
    if (!t.classList.contains('have-check')) return;
    if (t.checked) pantry[t.dataset.item!] = true;
    else delete pantry[t.dataset.item!];
    localStorage.setItem(PANTRY_KEY, JSON.stringify(pantry));
    render();
  });

  // filters picker rows only; checked-but-hidden recipes stay on the list
  const pickerSearch = document.getElementById('picker-search') as HTMLInputElement;
  const pickerRows = picker.querySelectorAll<HTMLElement>('.picker-row');
  pickerSearch.addEventListener('input', () => {
    const q = pickerSearch.value.trim().toLowerCase();
    pickerRows.forEach((row) => {
      row.style.display = q === '' || row.dataset.search!.includes(q) ? '' : 'none';
    });
  });

  copyBtn.addEventListener('click', () => {
    const selected = selectedFromState(currentState());
    const groups = groupBySection(aggregateIngredients(selected, gramConversions));
    const text = groups
      .map((g) => ({ ...g, lines: g.lines.filter((l) => !pantry[l.item]) }))
      .filter((g) => g.lines.length > 0)
      .map(
        (g) =>
          `${g.section.toUpperCase()}\n` +
          g.lines
            .map((l) => {
              const d = lineDisplay(l);
              return `- ${d.qty} ${l.item}${d.need ? ` (need ${d.need})` : ''}`;
            })
            .join('\n'),
      )
      .join('\n\n');
    navigator.clipboard.writeText(text).then(() => {
      copyConfirm.textContent = 'Copied';
      setTimeout(() => {
        copyConfirm.textContent = '';
      }, 2000);
    });
  });

  clearBtn.addEventListener('click', () => {
    picker.querySelectorAll<HTMLInputElement>('.recipe-check').forEach((cb) => {
      cb.checked = false;
    });
    picker.querySelectorAll<HTMLInputElement>('.recipe-qty').forEach((input) => {
      const recipe = recipesForClient.find((r) => r.id === input.dataset.id);
      if (recipe) input.value = String(recipe.primaryQty);
    });
    render();
  });
</script>
