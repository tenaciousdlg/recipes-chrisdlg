---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { getPrimaryIngredient } from '../lib/scale';
import { isHighProtein } from '../lib/macros';

const recipes = (await getCollection('recipes')).sort(
  (a, b) => b.data.created.getTime() - a.data.created.getTime(),
);
---

<Layout title="Recipes">
  {
    recipes.map((recipe) => {
      const primary = getPrimaryIngredient(recipe.data.ingredients);
      return (
        <a class="recipe-card" href={`/recipes/${recipe.id}/`}>
          <h2>
            {recipe.data.title}
            {recipe.data.category === 'base' && <span class="tag category-tag">base</span>}
          </h2>
          <p>{recipe.data.description}</p>
          <div class="recipe-meta">
            {recipe.data.base_servings} servings from {primary.qty} {primary.unit} {primary.item}
            {recipe.data.cuisine ? ` · ${recipe.data.cuisine}` : ''}
          </div>
          <div class="tags">
            {isHighProtein(recipe.data.macros_per_serving) && <span class="tag">high-protein</span>}
            {recipe.data.tags.map((tag) => <span class="tag">{tag}</span>)}
          </div>
        </a>
      );
    })
  }
</Layout>
